[Unit]
Description=LogMeIn Hamachi daemon
After=local-fs.target network.target
Before=nftables.service

[Service]
ExecStart=/opt/logmein-hamachi/bin/hamachid
Type=forking

[Install]
WantedBy=multi-user.target

mkinitcpio -P


# installing Limine
pacman -S limine

mkdir /boot/EFI/limine
cp /usr/share/limine/BOOTX64.EFI /boot/EFI/limine
efibootmgr \
      --create \
      --disk /dev/nvme0nX \
      -p Y \
      --label "Arch Linux Limine Boot Loader" \
      --loader '\EFI\limine\BOOTX64.EFI' \
      --unicode
nvim /boot/EFI/limine/limine.conf
||
timeout: 5
remember_last_entry: yes

term_palette: 1e1e2e;f38ba8;a6e3a1;f9e2af;89b4fa;f5c2e7;94e2d5;cdd6f4
term_palette_bright: 585b70;f38ba8;a6e3a1;f9e2af;89b4fa;f5c2e7;94e2d5;cdd6f4
term_background: 321e1e2e
term_foreground: cdd6f4
term_background_bright: 585b70
term_foreground_bright: cdd6f4

wallpaper: boot():/limine/wallpaper.png
wallpaper_style: centered
backdrop: 1e1e2e

${PUUID}=d2d48794-027d-4661-96df-b61ecee6c6b7
${LTHEME}=vt.default_red=30,243,166,249,137,245,148,186,88,243,166,249,137,245,148,166 vt.default_grn=30,139,227,226,180,194,226,194,91,139,227,226,180,194,226,173 vt.default_blu=46,168,161,175,250,231,213,222,112,168,161,175,250,231,213,200

/+Arch Linux
//linux
    protocol: linux
    path: boot():/vmlinuz-linux
    cmdline: root=PARTUUID=${PUUID} rootflags=subvol=@ rw rootfstype=btrfs ${LTHEME}
    module_path: boot():/initramfs-linux.img
//linux-lts
    protocol: linux
    path: boot():/vmlinuz-linux-lts
    cmdline: root=PARTUUID=${PUUID} rootflags=subvol=@ rw rootfstype=btrfs ${LTHEME}
    module_path: boot():/initramfs-linux-lts.img
||

nvim /etc/pacman.d/hooks/99-limine.hook
||
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = limine              

[Action]
Description = Deploying Limine after upgrade...
When = PostTransaction
Exec = /usr/bin/cp /usr/share/limine/BOOTX64.EFI /boot/EFI/limine/
||


